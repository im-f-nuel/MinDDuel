# Copy this file to .env.local and fill in values
# NEVER commit .env.local

# ── Solana RPC endpoint ───────────────────────────────────────────────
# The public devnet endpoint (https://api.devnet.solana.com) rate-limits
# aggressively (~10 req/sec) and the app WILL hit 429 errors during a
# real match. Use one of these instead:
#
#   Helius (free tier, sign up at helius.dev):
#     https://devnet.helius-rpc.com/?api-key=YOUR_KEY
#
#   QuickNode (free tier):
#     https://your-endpoint.solana-devnet.quiknode.pro/YOUR_TOKEN/
#
#   Triton One:
#     https://api.devnet.rpcpool.com/YOUR_TOKEN
#
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Program ID (set after anchor deploy)
NEXT_PUBLIC_PROGRAM_ID=8XZTXNux374128LFJSVhp5XSNyYMPNZpfw4vyjWmSJkN

# Trivia backend URL
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Mock USDC mint (devnet) — set after running `npm run setup:usdc` in backend
NEXT_PUBLIC_MOCK_USDC_MINT=
