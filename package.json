    "lint": "npm run lint --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=frontend && npm run typecheck --workspace=backend"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "ts-mocha": "^11.1.0",
    "typescript": "^6.0.3"
  }
}
